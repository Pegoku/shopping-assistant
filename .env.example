WHATSAPP_PROVIDER=webjs
WHATSAPP_DEFAULT_TO=
APP_BASE_URL=
# Examples:
# - same machine: http://localhost:3000
# - another PC on your LAN: http://192.168.1.50:3000

# whatsapp-web.js
WHATSAPP_SESSION_NAME=shopping-assistant
WHATSAPP_WEBJS_DATA_PATH=.wwebjs_auth
WHATSAPP_WEBJS_HEADLESS=true
WHATSAPP_WEBJS_CHROME_PATH=

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_META_API_VERSION=v23.0

# AH/Jumbo-only outbound proxy. In Docker this points at the ProtonVPN sidecar.
SCRAPER_PROXY_URL=

# Docker ProtonVPN sidecar. Generate this from ProtonVPN's WireGuard config.
PROTONVPN_WIREGUARD_PRIVATE_KEY=
PROTONVPN_SERVER_COUNTRIES=Netherlands

# AI provider used for text and receipt image scanning.
HACKCLUB_AI_API_KEY=
HACKCLUB_AI_BASE_URL=https://ai.hackclub.com/proxy/v1
HACKCLUB_AI_MODEL=
HACKCLUB_AI_RECEIPT_MODEL=google/gemini-3.1-flash-lite
HACKCLUB_AI_RECEIPT_MAX_TOKENS=5000
