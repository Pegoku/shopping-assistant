generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Supermarket {
  AH
  JUMBO
}

enum FetchStatus {
  PENDING
  SUCCESS
  PARTIAL
  CANCELLED
  FAILED
}

enum PastOrderSource {
  MANUAL
  AI_RECEIPT
  WHATSAPP
}

model Product {
  id               String            @id @default(cuid())
  supermarket      Supermarket
  originalName     String
  genericNameEn    String
  genericNameEs    String
  quantityText     String
  unitAmount       Float?
  normalizedUnit   String?
  currentPrice     Float
  currentUnitPrice Float?
  imageUrl         String?
  sourceUrl        String?
  dealText         String?
  isDealActive     Boolean           @default(false)
  lastFetchedAt    DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  categories       ProductCategory[]
  priceHistory     PriceHistory[]
  adminEdits       AdminEdit[]
  receiptAliases   ReceiptProductAlias[]
  pastOrderItems   PastOrderItem[]
}

model Person {
  id        String           @id @default(cuid())
  name      String           @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  paidOrders PastOrder[]      @relation("PastOrderPayer")
  itemShares PastOrderItemShare[]
  settlementPaymentsFrom PastOrderSettlementPayment[] @relation("SettlementPaymentFrom")
  settlementPaymentsTo   PastOrderSettlementPayment[] @relation("SettlementPaymentTo")
}

model PastOrder {
  id              String          @id @default(cuid())
  supermarket     Supermarket
  source          PastOrderSource @default(MANUAL)
  orderedAt       DateTime        @default(now())
  payerId         String?
  total           Float           @default(0)
  rawReceiptText  String?
  receiptImageName String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  payer           Person?         @relation("PastOrderPayer", fields: [payerId], references: [id], onDelete: SetNull)
  items           PastOrderItem[]
  settlementPayments PastOrderSettlementPayment[]

  @@index([orderedAt])
  @@index([supermarket])
}

model PastOrderSettlementPayment {
  id           String    @id @default(cuid())
  orderId      String
  fromPersonId String
  toPersonId   String
  paidAt       DateTime  @default(now())
  order        PastOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromPerson   Person    @relation("SettlementPaymentFrom", fields: [fromPersonId], references: [id], onDelete: Cascade)
  toPerson     Person    @relation("SettlementPaymentTo", fields: [toPersonId], references: [id], onDelete: Cascade)

  @@unique([orderId, fromPersonId, toPersonId])
  @@index([fromPersonId])
  @@index([toPersonId])
}

model PastOrderItem {
  id             String      @id @default(cuid())
  orderId        String
  productId      String?
  receiptName    String
  quantity       Float       @default(1)
  unitPrice      Float?
  totalPrice     Float
  aiConfidence   Float?
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  order          PastOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  shares         PastOrderItemShare[]

  @@index([orderId, sortOrder])
  @@index([productId])
}

model PastOrderItemShare {
  id        String        @id @default(cuid())
  itemId    String
  personId  String
  percent   Float
  item      PastOrderItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  person    Person        @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([itemId, personId])
  @@index([personId])
}

model ReceiptProductAlias {
  id          String      @id @default(cuid())
  supermarket Supermarket
  alias       String
  normalized  String
  productId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supermarket, normalized])
  @@index([productId])
}

model Category {
  id        String            @id @default(cuid())
  slug      String            @unique
  label     String
  products  ProductCategory[]
  createdAt DateTime          @default(now())
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model PriceHistory {
  id          String      @id @default(cuid())
  productId   String
  price       Float
  unitPrice   Float?
  isDeal      Boolean     @default(false)
  dealText    String?
  capturedAt  DateTime    @default(now())
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, capturedAt])
}

model FetchRun {
  id                String       @id @default(cuid())
  status            FetchStatus  @default(PENDING)
  supermarket       Supermarket?
  sourceMode        String
  startedAt         DateTime     @default(now())
  completedAt       DateTime?
  itemsFetched      Int          @default(0)
  itemsCreated      Int          @default(0)
  itemsUpdated      Int          @default(0)
  itemsDiscovered   Int          @default(0)
  itemsExpected     Int?
  pagesProcessed    Int          @default(0)
  pagesExpected     Int?
  categoriesDone    Int          @default(0)
  categoriesTotal   Int?
  currentStore      String?
  currentCategory   String?
  currentMessage    String?
  progressPercent   Float        @default(0)
  warningCount      Int          @default(0)
  ahCategoriesDone  Int          @default(0)
  ahCategoriesTotal Int?
  ahPagesProcessed  Int          @default(0)
  ahPagesExpected   Int?
  ahItemsFound      Int          @default(0)
  ahWarnings        Int          @default(0)
  ahCurrentCategory String?
  ahCurrentMessage  String?
  ahCompletedAt     DateTime?
  jumboCategoriesDone  Int       @default(0)
  jumboCategoriesTotal Int?
  jumboPagesProcessed  Int       @default(0)
  jumboPagesExpected   Int?
  jumboItemsFound      Int       @default(0)
  jumboWarnings        Int       @default(0)
  jumboCurrentCategory String?
  jumboCurrentMessage  String?
  jumboCompletedAt     DateTime?
  errorMessage      String?
}

model AdminEdit {
  id            String    @id @default(cuid())
  productId     String
  fieldName     String
  previousValue String?
  nextValue     String?
  createdAt     DateTime  @default(now())
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

model AiNameCache {
  id            String   @id @default(cuid())
  originalName  String   @unique
  genericNameEn String
  genericNameEs String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SharedCartItem {
  id            String      @id
  originalName  String
  genericNameEn String
  genericNameEs String
  supermarket   Supermarket
  currentPrice  Float
  quantityText  String
  imageUrl      String?
  quantity      Int         @default(1)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model SharedFavouriteItem {
  id            String      @id
  originalName  String
  genericNameEn String
  genericNameEs String
  supermarket   Supermarket
  currentPrice  Float
  quantityText  String
  imageUrl      String?
  quantity      Int         @default(1)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
